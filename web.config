<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Triggering IIS reload v7 -->
    <system.webServer>
        <!-- Disables directory browsing for security -->
        <directoryBrowse enabled="false" />

        <handlers>
            <!-- Pass all requests through to the HttpPlatformHandler -->
            <add name="httpPlatformHandler" path="*" verb="*" modules="httpPlatformHandler" resourceType="Unspecified" />
        </handlers>

        <!-- 
            processPath: The path to the node executable. 
            arguments: The path to the entry point of your server.
            stdoutLogEnabled: Set to true to capture console logs for debugging.
        -->
        <httpPlatform processPath="C:\Program Files\nodejs\node.exe"
                      arguments=".\server\server.js"
                      stdoutLogEnabled="true"
                      stdoutLogFile=".\logs\node_stdout.log"
                      startupTimeLimit="120"
                      requestTimeout="00:05:00"
                      processesPerApplication="1">
            <environmentVariables>
                <!-- IIS provides a random port via %HTTP_PLATFORM_PORT% -->
                <environmentVariable name="PORT" value="%HTTP_PLATFORM_PORT%" />
                <environmentVariable name="NODE_ENV" value="production" />
            </environmentVariables>
        </httpPlatform>
    </system.webServer>
</configuration>
